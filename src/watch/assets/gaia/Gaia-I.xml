  <init	expr='hourWheelOR=dot1Rad-4, hourWheelIR=hourWheelOR-hour12FS-2' />
  <init expr='ringOR=hourWheelOR, ringW=5, ringIR=hourWheelIR, dnNum=48' />
  <init expr='hour12IR=ringIR-2' />
  <init expr='dotZ=3, dotThick=1.5' />

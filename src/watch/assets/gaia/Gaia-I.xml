<!-- == Front ==     a multi-subdial watch showing 4 timezones -->

<init expr='ampmFS=8, wheelFS=11, labelFS=12, ringW=3' />
<!-- positions -->
<init expr='lsx=-58.5, lsy=0, lsR=58' />
<init expr='sR=32, sRa=53.88, ang=1.17809725, labR=sR+ringW+labelFS+7.5, llabR=lsR+ringW+labelFS+7.5' />
<init expr='s1x=32.19, s1y=77.716, s1xx=32, s1yy=78' />
<init expr='s2x=84.12, s2y= 0,     s2xx=84, s2yy= 0' />
<init expr='s3x=32.19, s3y=-77.72, s3xx=32, s3yy=-78' />
<init expr='moonx=-45, moony=105, moonr=14' />

<init expr='th=0*2*pi/360, lr=sqrt(lsx*lsx+lsy*lsy), sr=sqrt(s1x*s1x+s1y*s1y), lth=atan(lsy/lsx)+th, s1th=atan(s1y/s1x)+th,  s2th=atan(s2y/s2x)+th,  s3th=atan(s3y/s3x)+th,
	      lsx=-lr*cos(lth), s1x= sr*cos(s1th), s2x= sr*cos(s2th), s3x= sr*cos(s3th),
	      lsy=-lr*sin(lth), s1y= sr*sin(s1th), s2y= sr*sin(s2th), s3y= sr*sin(s3th) '/>

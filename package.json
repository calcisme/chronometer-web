{
  "name": "chronometer-web",
  "version": "0.1.0",
  "description": "Web port of the Emerald Chronometer watch app",
  "type": "module",
  "scripts": {
    "build": "bash build.sh",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:capture": "CAPTURE=1 vitest run src/__tests__/regression/",
    "test:regression": "vitest run src/__tests__/regression/"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
